[DEFAULT]
bantime  = 3600   # 1 giờ — đổi thành số nhỏ (ví dụ 2) để test
findtime = 60
maxretry = 10
backend  = auto

[openresty-403]
enabled  = true
port     = http,https
filter   = openresty-403
logpath  = /usr/local/openresty/nginx/logs/access.log
maxretry = 10
findtime = 60
bantime  = 3600

[openresty-429]
enabled  = true
port     = http,https
filter   = openresty-429
logpath  = /usr/local/openresty/nginx/logs/access.log
maxretry = 5
findtime = 60
bantime  = 7200
